generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  INSTRUCTOR
}

enum EstadoCuenta {
  BORRADOR
  PENDIENTE
  APROBADA
  RECHAZADA
  PAGADA
}

enum TipoCuenta {
  AHORROS
  CORRIENTE
}

enum Categoria {
  A2
  B1
  C1
  C2
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  password         String
  nombre           String
  apellido         String
  cedula           String        @unique
  telefono         String?
  direccion        String?
  ciudadExpedicion  String?
  foto             String?
  role             Role          @default(INSTRUCTOR)
  activo           Boolean       @default(true)
  setupCompleto    Boolean       @default(false)
  banco            String?
  tipoCuenta       TipoCuenta?
  numeroCuenta     String?
  sede             Sede?         @relation(fields: [sedeId], references: [id])
  sedeId           String?
  cuentasCobro     CuentaCobro[]
  tarifas          TarifaInstructor[]
  historialCambios HistorialEstado[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@map("users")
}

model Sede {
  id           String        @id @default(cuid())
  nombre       String
  direccion    String
  activa       Boolean       @default(true)
  usuarios     User[]
  cuentasCobro CuentaCobro[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("sedes")
}

model CuentaCobro {
  id             String       @id @default(cuid())
  numero         Int          @unique @default(autoincrement())
  instructor     User         @relation(fields: [instructorId], references: [id])
  instructorId   String
  sede           Sede         @relation(fields: [sedeId], references: [id])
  sedeId         String
  concepto       String
  descripcion    String?
  valor          Decimal      @db.Decimal(12, 2)
  periodoInicio  DateTime
  periodoFin     DateTime
  estado         EstadoCuenta @default(PENDIENTE)
  observaciones  String?
  fechaPago      DateTime?
  items          CuentaItem[]
  historial      HistorialEstado[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("cuentas_cobro")
}

model TarifaInstructor {
  id           String    @id @default(cuid())
  instructor   User      @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  instructorId String
  categoria    Categoria
  valorHora    Decimal   @db.Decimal(12, 2)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([instructorId, categoria])
  @@map("tarifas_instructor")
}

model CuentaItem {
  id        String      @id @default(cuid())
  cuenta    CuentaCobro @relation(fields: [cuentaId], references: [id], onDelete: Cascade)
  cuentaId  String
  fecha     DateTime    @db.Date
  horas     Int
  categoria Categoria
  valorHora Decimal     @db.Decimal(12, 2)
  subtotal  Decimal     @db.Decimal(12, 2)
  createdAt DateTime    @default(now())

  @@index([cuentaId])
  @@map("cuenta_items")
}

model HistorialEstado {
  id             String       @id @default(cuid())
  cuenta         CuentaCobro  @relation(fields: [cuentaId], references: [id], onDelete: Cascade)
  cuentaId       String
  estadoAnterior EstadoCuenta
  estadoNuevo    EstadoCuenta
  observacion    String?
  cambiadoPor    User         @relation(fields: [cambiadoPorId], references: [id])
  cambiadoPorId  String
  createdAt      DateTime     @default(now())

  @@index([cuentaId])
  @@map("historial_estados")
}
